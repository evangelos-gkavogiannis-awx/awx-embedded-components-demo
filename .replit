run = "pnpm start"
entrypoint = "backend/src/start.js"

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
build = "npm install -g pnpm && pnpm install && pnpm build"
run = "node --import ./backend/src/proxy-bootstrap.js backend/src/server.js"